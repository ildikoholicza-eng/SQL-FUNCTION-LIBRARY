--1, Customer Lifetime Value is also great for segmentation, identify high value customers

SELECT 
customer_id,
COUNT(order_id) AS total_orders,
SUM(order_value) AS total_spent,
AVG(order_value) AS avg_order_vale,
MAX(order_date) AS last_purchase_dt,
DATEDIFF(CURRENT_DATE,MAX(order_date) AS days_since_last_prch
FROM orders_table
GROUP BY customer_id;

--2, Churn risk indicator, customers likely to stop buying, for retention models, email targeting

SELECT customer_id,
MAX(order_date) AS last_order_dt,
DATEDIFF(CURRENT_DATE, MAX(order_date)) AS days_inactive,
COUNT(order_id) AS order_count,
CASE
	WHEN DATEDIFF(CURRENT_DATE, MAX(order_date))>60 THEN 1
	ELSE 0
END AS churn_flag
FROM orders_table
GROUP BY customer_id


--3, Purchase frequency (behaviour intensity). engagement level, future activity

SELECT 
customer_id,
COUNT(order_id) * 1.0/ NULLIF(DATEDIFF(MAX(order_date),MIN(order_date)),0) AS purchase_frqcy
FROM orders_table
GROUP BY customer_id

--4, Product Affinity (recommendation signal) "customer also bought" 

SELECT a.customer_id,
a.product_id,
b.product_id AS related_product
COUNT(*) AS times_bought_together,
FROM order_items a
JOIN order_items b
ON a.order_id = b.order_id 
AND a.product_id <> b.product_id
GROUP BY a.customer_id, a.product_id, b.product_id
ORDER BY times_bought_togehter DESC;


--5, Revenue trend per customer (using window functions). Customer growth trajectory, high-value trajectory user
SELECT 
customer_id, 
order_date
SUM(order_value) OVER(PARTITION BY customer_id 
ORDER BY order_date) AS cumulative_spend
FROM orders_table;

-- 6, Recency, frequency, monetry ( RFM model), marketing segmentation, targeting campaigns

SELECT customer_id
DATEDIFF(CURRENT_DATE, MAX(order_date)) AS recency,
COUNT(order_id) AS frequncy,
SUM(order_value) AS monetary
FROM orders_table
GROUP BY customer_id;


--7, Time between purchases, when the customer will buy next

SELECT customer_id,
AVG(days_between_orders) AS avg_days_btw_orders
FROM
(

SELECT
customer_id,
order_date - LAG(order_date)OVER(PARTITION BY customer_id
ORDER BY order_date) AS dys_btwn_orders
FROM orders_table)t
GROUP BY customer_id;


--8, Drop-off detection (behaviour change), declining engagement, early churn signals. 


SELECT 
customer_id,
order_date,
order_value,
order_calue - LAG(order_value) OVER(PARTITION BY order_date) AS value_change
FROM
orders_table;


