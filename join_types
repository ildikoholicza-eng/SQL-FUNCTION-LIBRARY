=======================================================================================================

Set Operators: Joining tables horizontally. each table needs to have the same number oc columns with matching 
data type and the same name for the columns 
============================================================================================================
*/

--Union. Combine leads from multiple campaigns, remove duplicates
SELECT 
user_id 
FROM facebook_leads
UNION
SELECT user_id
FROM google_leads;


--Union All. Combines all. Measure total volume per channel. All rows, including duplicates

SELECT
user_id 
FROM facebook_leads
UNION ALL
SELECT 
user_id 
FROM google_leads;


--Intersect. Users who engaged with both campaigns. Overlapping users

SELECT 
user_id 
FROM email_campaign
INTERSECT 
SELECT
user_id 
FROM paid_ads;

--Except (minus). Users in campaign A but not in campaign B. 

SELECT user_id
FROM 
email_campaign
EXCEPT 
SELECT 
user_id
FROM paid_ads;

