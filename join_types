-- Inner Join. Matches users who both signed up and made a purchase
SELECT *
FROM users_table u
INNER JOIN orders_table o ON u.user_id = o.user_id;

-- Left Join. Keeps all the users, even those who did not purchase, where available, otherwise NULL

SELECT *
FROM user_table u
LEFT JOIN orders_table o ON u.user_id = o.user_id;

--Right Join. Keep all purchases, even if users data is missing. Audit data quality or missing user tracking
--Result:All orders and matching users, otherwise NULL
SELECT *
FROM users_table u
RIGHT JOIN orders o ON u.user_id = o.user_id;


--Full Outer Join combines all users and all orders. Tracking gaps and mismatches, everything from both tables matched where possible

SELECT *
FROM users_table u
FULL JOIN orders_table o ON u.user_id = o.user_id;

--Cross Join. Combine every campaign with every audience segment. Generates all targeting combinations. 
-- Campaigns × segments (all possibilities)
SELECT *
FROM 
campaign_table c
CROSS JOIN segments s ;

--Self Join. Compare a user's current vs previous behaviour. Track behaviour change. Same table linked across time/events
SELECT
a.user_id, b.user_id AS referred_user
FROM users a
JOIN users b ON a.user_id = b.referred_id;


-- Non Equi Join. Assign users to marketing tiers based on spend. Users matched to ranges like VIP tiers.

SELECT *
FROM users_table u
JOIN tiers_table t ON u.total_spent BETWEEN t.min_spend AND t.max_spend;

--Left Semi Join. Users who clicked on a campaign. Filter out the audience based on behaviour. Result at least one match.

SELECT *
FROM users_table u
WHERE EXISTS 
(
SELECT 1 
FROM clicks c 
WHERE u.user_id = c.user_id);


--Left Anti Join. Users who did not purchase. For retargeting campaigns. Result: Users with no match.in orders

SELECT *
FROM users_table u
WHERE NOT EXISTS 
( 
SELECT 1
FROM orsers o 
WHERE u.users_id = o.user_id);


